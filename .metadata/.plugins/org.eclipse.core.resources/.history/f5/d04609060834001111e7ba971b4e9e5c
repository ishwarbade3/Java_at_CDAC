package p2.p3;
import p1.Date;

public class Employee {
	private int empId;
	private String empName;
	private Date joiningDate;
	
	public Employee(){}	
	public Employee(int empId,String empName,Date dt){
		this.empId=empId;
		this.empName=empName;
		this.joiningDate=dt;
	}
	public String toString() {
		return empId+ " "+empName+ " "+ joiningDate;
	}
	public static void main(String[]ishwar) {
	   Employee e =new Employee(1213,"Iahwar",new Date(12,04,2026));
	   System.out.println(e);
	}
}
