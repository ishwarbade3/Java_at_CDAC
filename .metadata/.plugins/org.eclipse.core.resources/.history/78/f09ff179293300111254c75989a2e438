import java.util.Scanner;
public class MathOperation {
	 private int x;
	 private int y;
	 private int r;
	 
	 public MathOperation() {}
	 
	 public void initData(int x,int y) {
		 this.x=x;
		 this.y=y;
	 }
	 public void add() {
		 r=x+y;
	 }
	 public void multiply() {
		 r=x*y;
	 }
	 public void power() {
		 r=1;
		 for(int i = 1;i<=y;i++) {
			 r*=x;
		 }
	 }
	 public void display() {
		 System.out.println("Result : "+r);
	 }
	 
	 public static void main(String[]ishwar) {
		Scanner kbd = new Scanner(System.in);
		System.out.println("Enter two Number");
		int a = kbd.nextInt();
		int b = kbd.nextInt();
		MathOperation m = new MathOperation();
		m.initData(a, b);
		m.add();
		m.display();
		m.multiply();
		m.display();
		m.power();
		m.power();
		
		
		kbd.close();
	 }
}
