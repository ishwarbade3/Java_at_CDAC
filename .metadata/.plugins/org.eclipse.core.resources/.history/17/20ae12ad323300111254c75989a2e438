
public class Person {
	private String personName;
	private byte personAge;
	
	public Person(){
		personAge=18;
	}
	public Person(String personName, byte personAge) {
		this.personName=personName;
		this.personAge=personAge;	
	}
	public void displayPerson()
	{
		System.out.println(" Name : "+personName+", Age : "+personAge);
	}
	public static void main(String[]ishwar) {
		Person p = new Person();
		p.displayPerson();
		Person p1 = new Person("Siddhart",(byte) 22);
		p1.displayPerson();
	}
}
