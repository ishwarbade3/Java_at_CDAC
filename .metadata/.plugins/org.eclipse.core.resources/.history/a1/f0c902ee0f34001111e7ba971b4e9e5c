package arrays;

import java.util.Scanner;

public class JaggedArray {
	public static void main(String[] ishwar) {

		Scanner kbd = new Scanner(System.in);
		System.out.print("Enter array Row Size : ");
		int rowSize = kbd.nextInt();
		int[][] arr = new int[rowSize][];
		System.out.println("Enter array Element : ");
		for (int i = 0; i < rowSize; i++) {
			System.out.print("Enter array Column Size at row number " + i + " : ");
			int colSize = kbd.nextInt();
			arr[i] = new int[colSize];
			for (int j = 0; j < colSize; j++) {
				System.out.print("Enter array Element at index [" + i + "] [" + j + "] : ");
				arr[i][j] = kbd.nextInt();
			}
		}
		System.out.println("Array Becomes : ");
