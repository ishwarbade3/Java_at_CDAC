import java.util.Scanner;

public class XYZ {
	private int arr[][] = new int[5][3];
	protected Scanner kbd = new Scanner(System.in);

	public void acceptData() {
		System.out.println("Enter the data (productID,Price,Quantity)");
		for (int i = 0; i < 5; i++) {
			for (int j = 0; j < 3; j++) {
				System.out.print(" Enter Data of " + i + " product : ");
				arr[i][j] = kbd.nextInt();
			}
		}
	}
	public void highPriceID() {
		int high = 0;
		int price=0;
		int id=0;
		for (int i = 0; i < 5; i++) {
			for (int j = 0; j < 3; j++) {
				if (arr[i][1] * arr[i][2] > high) {
					 high =arr[i][1] * arr[i][2];
					 price =arr[i][1];
					 id=arr[i][0];
				}
			}
		}
		System.out.println("P_ID : "+id+" with highest price : "+price);
	}
	public static void main(String[] args) {
		XYZ x = new XYZ();
		x.acceptData();
		x.highPriceID();
		
	}

}
