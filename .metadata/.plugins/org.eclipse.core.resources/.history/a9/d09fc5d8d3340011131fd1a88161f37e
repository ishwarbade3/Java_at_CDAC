package person_hierarchi;

public class Person {
	private String fName;
	private String lName;
	private int age;
	
	public Person() {}
	public Person(String fName,String lName,int age) {
		this.fName=fName;
		this.lName=lName;
		this.age=age;
	}
	public String toString()
	{
		return fName +" "+lName+" "+age+" ";
	}
}
