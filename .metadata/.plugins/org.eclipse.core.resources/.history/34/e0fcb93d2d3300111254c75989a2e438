
public class MathOperation1 {
	public MathOperation1() {}
	
	public int multiply(int a, int b) {
		return a*b;
	}
	public float multiply(float a,float b, float c) {
		return a*b*c;
	}
	public double multiply(int a,double b) {
		return(double )a*b;
	}
	public double multiply(int a[]) {
		int result =1;
		for( int x :a ) {
			result *=x;
		}
		return result;
	}
	public static void main(String []ishwar) {
		MathOperation1 m= new MathOperation1();
		int x=10;
		double y= 15;
		System.out.println(m.multiply(x,y));
		System.out.println(m.multiply(7,5));
	}

}
