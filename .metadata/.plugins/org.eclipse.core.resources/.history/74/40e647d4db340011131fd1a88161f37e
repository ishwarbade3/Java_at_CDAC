
public class Employee {
	private static int empNo;
	private double salary;
	private static double totalSalary =0;

	public Employee() {
	}

	public Employee(double salary) {
		empNo++;
		this.salary = salary ;
		totalSalary += this.salary;
	}

	public void display() {
		System.out.println("Employee  : "+ empNo+" Total Salary : "+Salary);
	}
	public static void displaydata() {
		System.out.println("Total Employee : "+ empNo+" And Total Salary : "+totalSalary);
	}
	public static void main(String[] args) {
		Employee e1 =new Employee(25000);
		Employee e2 =new Employee(25000);
		Employee e3 =new Employee(20000);
		
		e1.display();
		e2.display();
		e3.display();
		
		Employee e4 =new Employee(25000);
		e4.display();
		Employee e5 =new Employee(25000);
		e5.display();
		Employee e6 =new Employee(25000);
		e6.display();
		Employee.displaydata();
	}

}
