package p1;

public class Date {
	private int dd;
	private int mm;
	private int yy;
	public Date() {}
	public Date(int dd,int mm,int yy) {
		this.dd=dd;
		this.mm=mm;
		this.yy=yy;
	}
	public String toString() {
		return dd+"/"+mm+"/"+yy;
	}
	public static void swapDate(Date d1,Date d2) {
		Date temp;
		temp=d1;
		d1=d2;
		d2=temp;
	}
	public static void main(String[]ishwar) {
		Date d1 =new Date(12,04,2026);
		Date d2 =new Date(04,04,2026);
		System.out.println("Date Before :"+d1);
		System.out.println("Date Before :"+d1);
		Date.swapDate(d1, d2);
		System.out.println("Date After :"+d1);
		System.out.println("Date After :"+d1);
	}
}
